# aerial_ws isolated simulation defaults for AI-agent operation.
# Copy to .env for local overrides. Do not commit .env.

# This project is isolated; all containers and host ROS terminals must use domain 22.
ROS_DOMAIN_ID=22

# Foxglove WebSocket bridge for this repo. Connect with ws://<host-ip>:8865.
FOXGLOVE_PORT=8865

# Isaac Sim distribution target.
ISAAC_SIM_VERSION=6.0.0

# 1 = headless container run, 0 = headed/X11. Headed mode needs xhost +local:docker.
HEADLESS=1
DISPLAY=:0

# Optional Pegasus Simulator extension path inside the Isaac Sim container.
# Mount/provide this path if Pegasus is installed outside this repo.
# Example: /workspace/pegasus/PegasusSimulator/extensions/pegasus.simulator
PEGASUS_EXT_PATH=

# Optional --exec script inside the Isaac Sim container.
# Example: /workspace/aerial_ws/scripts/spawn_pegasus_drone.py
ISAAC_SIM_EXEC=

# Foxglove bridge runtime image. It installs ros-humble-foxglove-bridge on first start.
FOXGLOVE_ROS_IMAGE=ros:humble-ros-base
