# Complete inspection result for dashboard/backend
std_msgs/Header header
string drone_id
string mission_id
string zone_id

# Drone pose at time of inspection
geometry_msgs/PoseStamped drone_pose

# Defects found
pegasus_msgs/DefectArray defects

# Zone coverage info
float32 coverage_percent
uint32 images_captured
uint32 images_with_defects

# Overall zone risk
string zone_risk_level
uint8 zone_risk_id

# JSON payload (for direct backend ingestion)
string json_payload
